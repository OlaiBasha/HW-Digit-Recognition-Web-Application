# Copy this file to .env and fill in once the backend is deployed.

# URL of your teammate's prediction endpoint, e.g. https://api.yourapp.com/predict
VITE_PREDICT_API_URL=https://hw-digit-recognition-web-application-production.up.railway.app/predict

# Set to "true" to use randomized mock predictions instead of calling the API
# (useful for building/testing the UI before the model is ready).
VITE_USE_MOCK_API=false
